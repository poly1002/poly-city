@page "/"

<div class="home-page">
    <div class="glass-card">
        <div class="icon-decor">🤍</div>
        <h1>Дорогая <span class="highlight">сестра</span></h1>
        <p class="subtitle">
            Поздравляю тебя с этим днём. <br />
            Пусть он будет тёплым, светлым и полным любви.
        </p>
        <div class="divider"></div>
        <p class="instruction">
            📱 Отсканируй QR-код, чтобы открыть <br /> <strong>секретные сюрпризы</strong>
        </p>

        <a href="/scanner" class="btn-scan">
            Открыть сканер
        </a>
    </div>

    <div class="how-it-works">
        <div class="step">
            <span class="step-icon">1</span>
            <p>Наведи на QR</p>
        </div>
        <span class="step-arrow">—</span>
        <div class="step">
            <span class="step-icon">2</span>
            <p>Сканируй</p>
        </div>
        <span class="step-arrow">—</span>
        <div class="step">
            <span class="step-icon">3</span>
            <p>Сюрприз</p>
        </div>
    </div>
</div>

<style>
    .home-page {
        min-height: 100vh;
        background: #f8f4ff;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 20px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        box-sizing: border-box;
        margin: -20px;
    }

    .glass-card {
        background: white;
        border-radius: 32px;
        padding: 40px 30px 35px;
        max-width: 420px;
        width: 100%;
        text-align: center;
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(0, 0, 0, 0.02);
        margin-bottom: 24px;
    }

    .icon-decor {
        font-size: 32px;
        margin-bottom: 12px;
        opacity: 0.5;
    }

    h1 {
        color: #2d1b3d;
        font-size: 30px;
        font-weight: 600;
        margin: 0 0 6px 0;
    }

    .highlight {
        background: linear-gradient(135deg, #6b4c7a, #8b6f9a);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 600;
    }

    .subtitle {
        font-size: 17px;
        color: #4a4a4a;
        font-weight: 400;
        line-height: 1.6;
        margin-bottom: 16px;
    }

    .divider {
        width: 32px;
        height: 2px;
        background: #d4c5d9;
        margin: 16px auto;
        border-radius: 4px;
    }

    .instruction {
        font-size: 16px;
        color: #4a4a4a;
        margin-bottom: 28px;
        line-height: 1.5;
        font-weight: 400;
    }

    .instruction strong {
        color: #6b4c7a;
        font-weight: 500;
    }

    .btn-scan {
        display: inline-block;
        padding: 14px 40px;
        background: #4f46e5;
        color: white !important;
        font-size: 17px;
        font-weight: 500;
        text-decoration: none;
        border-radius: 60px;
        box-shadow: 0 8px 30px rgba(79, 70, 229, 0.4);
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        letter-spacing: 0.3px;
        margin-top: 4px;
    }

    .btn-scan:active {
        transform: scale(0.97);
        background: #4338ca;
        box-shadow: 0 4px 20px rgba(79, 70, 229, 0.5);
    }

    .how-it-works {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        background: white;
        padding: 14px 28px;
        border-radius: 60px;
        max-width: 340px;
        width: 100%;
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.02);
        border: 1px solid rgba(0, 0, 0, 0.02);
    }

    .step {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .step-icon {
        font-size: 18px;
        font-weight: 600;
        color: #2d1b3d;
        opacity: 0.5;
    }

    .step p {
        margin: 6px 0 0 0;
        font-size: 12px;
        color: #8a8a8a;
        font-weight: 400;
        text-align: center;
        white-space: nowrap;
    }

    .step-arrow {
        font-size: 14px;
        color: #d4c5d9;
        opacity: 0.6;
    }
</style>
