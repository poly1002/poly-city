@page "/scanner"
@inject IJSRuntime JSRuntime

<div class="scanner-page">
    <div class="glass-card">
        <div class="icon-decor">📷</div>
        <h2>Наведи на QR-код</h2>
        <p class="subtitle">
            Найди QR-код на карточке и отсканируй
        </p>
        <div class="divider"></div>

        <div id="reader" class="scanner-box"></div>

        <button class="btn-scan" @onclick="StartCamera">
            ▶️ Запустить камеру
        </button>

        <p class="hint">💡 QR-код на твоей свадебной карточке</p>
    </div>

    <div class="how-it-works">
        <div class="step">
            <span class="step-icon">1</span>
            <p>Наведи на QR</p>
        </div>
        <span class="step-arrow">—</span>
        <div class="step">
            <span class="step-icon">2</span>
            <p>Сканируй</p>
        </div>
        <span class="step-arrow">—</span>
        <div class="step">
            <span class="step-icon">3</span>
            <p>Сюрприз</p>
        </div>
    </div>
</div>

<style>
    .scanner-page {
        min-height: 100vh;
        background: #f8f4ff;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 20px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        box-sizing: border-box;
        margin: -20px;
    }

    .glass-card {
        background: white;
        border-radius: 32px;
        padding: 35px 30px 30px;
        max-width: 420px;
        width: 100%;
        text-align: center;
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(0, 0, 0, 0.02);
        margin-bottom: 24px;
    }

    .icon-decor {
        font-size: 36px;
        margin-bottom: 8px;
        opacity: 0.6;
    }

    h2 {
        color: #2d1b3d;
        font-size: 26px;
        font-weight: 600;
        margin: 0 0 6px 0;
    }

    .subtitle {
        font-size: 16px;
        color: #4a4a4a;
        font-weight: 400;
        line-height: 1.5;
        margin-bottom: 16px;
    }

    .divider {
        width: 32px;
        height: 2px;
        background: #d4c5d9;
        margin: 12px auto 20px;
        border-radius: 4px;
    }

    .scanner-box {
        width: 100%;
        max-width: 320px;
        aspect-ratio: 1 / 1;
        margin: 0 auto 20px;
        background: #f3edf9;
        border-radius: 20px;
        overflow: hidden;
        border: 2px dashed #c9b8e8;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .scanner-box video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 18px;
    }

    .btn-scan {
        display: inline-block;
        padding: 14px 40px;
        background: #4f46e5;
        color: white !important;
        font-size: 17px;
        font-weight: 500;
        text-decoration: none;
        border-radius: 60px;
        box-shadow: 0 8px 30px rgba(79, 70, 229, 0.4);
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        letter-spacing: 0.3px;
        margin: 0 auto;
        width: auto;
    }

    .btn-scan:active {
        transform: scale(0.97);
        background: #4338ca;
        box-shadow: 0 4px 20px rgba(79, 70, 229, 0.5);
    }

    .hint {
        font-size: 14px;
        color: #8a8a8a;
        margin-top: 16px;
        font-weight: 400;
        letter-spacing: 0.2px;
    }

    .how-it-works {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        background: white;
        padding: 14px 28px;
        border-radius: 60px;
        max-width: 340px;
        width: 100%;
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.02);
        border: 1px solid rgba(0, 0, 0, 0.02);
    }

    .step {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .step-icon {
        font-size: 18px;
        font-weight: 600;
        color: #2d1b3d;
        opacity: 0.5;
    }

    .step p {
        margin: 6px 0 0 0;
        font-size: 12px;
        color: #8a8a8a;
        font-weight: 400;
        text-align: center;
        white-space: nowrap;
    }

    .step-arrow {
        font-size: 14px;
        color: #d4c5d9;
        opacity: 0.6;
    }
</style>

@code {
    private async Task StartCamera()
    {
        await JSRuntime.InvokeVoidAsync("startQrScanner");
    }
}