@inherits LayoutComponentBase

<div class="app-container">
    <!-- ШАПКА -->
    <div class="top-bar">
        <button class="menu-btn" @onclick="ToggleMenu">
            <span class="menu-icon">☰</span>
        </button>
        <span class="app-title">💜  Свадебный подарок</span>
    </div>

    <!-- ЗАТЕМНЕНИЕ -->
    <div class="sidebar-overlay @(isMenuOpen ? "open" : "")" @onclick="CloseMenu"></div>

    <!-- ВЫЕЗЖАЮЩЕЕ МЕНЮ -->
    <div class="sidebar @(isMenuOpen ? "open" : "")">
        <div class="sidebar-header">
            <span class="close-btn" @onclick="CloseMenu">✕</span>
            <h3>💜  Меню</h3>
        </div>
        <ul class="sidebar-nav">
            <li><NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="CloseMenu">🏠 Главная</NavLink></li>
            <li><NavLink class="nav-link" href="scanner" @onclick="CloseMenu">📷 Сканер QR</NavLink></li>

            <li><NavLink class="nav-link" href="final" @onclick="CloseMenu">💌  Письмо</NavLink></li>
        </ul>
        <div class="sidebar-footer">✨ Полина ❤️ </div>
    </div>

    <!-- ОСНОВНОЙ КОНТЕНТ -->
    <div class="main-content">
        @Body
    </div>
</div>

<style>
    /* ===== ФИОЛЕТОВО-ГОЛУБАЯ ТЕМА (меню как было) ===== */

    .app-container {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #f8f4ff;
        min-height: 100vh;
        position: relative;
        overflow: hidden;
    }

    /* ===== ШАПКА ===== */
    .top-bar {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        background: #4f46e5;
        color: white;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 2px 10px rgba(79, 70, 229, 0.3);
    }

    .menu-btn {
        background: none;
        border: none;
        color: white;
        font-size: 28px;
        padding: 0 8px 0 0;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
    }

    .app-title {
        font-size: 18px;
        font-weight: 600;
        margin-left: 8px;
        letter-spacing: 0.5px;
    }

    /* ===== ВЫЕЗЖАЮЩЕЕ МЕНЮ ===== */
    .sidebar {
        position: fixed;
        top: 0;
        left: -280px;
        width: 280px;
        height: 100%;
        background: white;
        box-shadow: 2px 0 20px rgba(79, 70, 229, 0.15);
        transition: left 0.3s ease;
        z-index: 200;
        padding: 20px 0;
        display: flex;
        flex-direction: column;
    }

        .sidebar.open {
            left: 0;
        }

    .sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 20px 16px 20px;
        border-bottom: 2px solid #ede9fe;
    }

        .sidebar-header h3 {
            margin: 0;
            background: linear-gradient(45deg, #7c3aed, #4f46e5);
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 20px;
            font-weight: 700;
        }

    .close-btn {
        font-size: 24px;
        color: #7c3aed;
        cursor: pointer;
        padding: 4px 8px;
        -webkit-tap-highlight-color: transparent;
    }

    .sidebar-nav {
        list-style: none;
        padding: 10px 0;
        margin: 0;
        flex: 1;
    }

        .sidebar-nav .nav-link {
            display: block;
            padding: 14px 20px;
            color: #2d1b3d;
            text-decoration: none;
            font-size: 17px;
            font-weight: 500;
            transition: background 0.15s;
            -webkit-tap-highlight-color: transparent;
            border-left: 4px solid transparent;
        }

            .sidebar-nav .nav-link:active {
                background: #ede9fe;
            }

            .sidebar-nav .nav-link.active {
                background: #ede9fe;
                15:02 color: #7c3aed;
                font-weight: 600;
                border-left: 4px solid #7c3aed;
            }

    .sidebar-footer {
        padding: 16px 20px;
        text-align: center;
        border-top: 1px solid #ede9fe;
        font-size: 14px;
        color: #7c3aed;
        font-weight: 500;
    }

    /* ===== ЗАТЕМНЕНИЕ ===== */
    .sidebar-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(79, 70, 229, 0.25);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
        z-index: 150;
        backdrop-filter: blur(3px);
        -webkit-backdrop-filter: blur(3px);
    }

        .sidebar-overlay.open {
            opacity: 1;
            pointer-events: auto;
        }

    /* ===== ОСНОВНОЙ КОНТЕНТ ===== */
    .main-content {
        padding: 0 0 20px 0;
        min-height: calc(100vh - 60px);
    }
</style>

@code {
    private bool isMenuOpen = false;

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }

    private void CloseMenu()
    {
        isMenuOpen = false;
    }
}/